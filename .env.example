# Base de datos PostgreSQL
DB_USER=postgres
DB_PASSWORD=tu_password_aqui
DB_HOST=localhost
DB_PORT=5432
DB_NAME=vitamar_logistics

# Servidor
PORT=3004
NODE_ENV=development

# OSRM (Open Source Routing Machine)
# Para local: http://localhost:5000
# Para cloud: https://router.project-osrm.org
OSRM_URL=http://router.project-osrm.org

# Google Maps API (opcional para geocodificación)
GOOGLE_MAPS_API_KEY=tu_api_key_aqui

# Widetech (si tienen API en el futuro)
WIDETECH_API_URL=https://api.widetech.com
WIDETECH_API_KEY=tu_key_aqui

# SIESA (si tienen API en el futuro)
SIESA_API_URL=https://api.siesa.com
SIESA_API_KEY=tu_key_aqui
